#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Supabase credentials (local dev)
.env
.env.admin
run_dev.sh
scripts/provision.log

# One-shot batch rosters (embedded rep data, per-cohort)
scripts/provision_reps_batch.sh
scripts/reset_reps_batch.sh

# Pilot rep temp-password sheets (plaintext passwords — distribute, then delete)
docs/pilot_reps_*.xlsx
docs/pilot_reps_*.tsv

# Merchant lead exports (plaintext NIDs — hand off to business unit, then delete)
docs/merchants_export_*.xlsx
docs/merchants_export_*.tsv

# Office owner-lock files (~$ prefix escapes the globs above; embed local username)
~$*

# Throwaway test harness (project-specific, not portable)
scripts/test/

# Temp credential files
credentials-temp.txt

# Android signing
*.keystore
*.jks
android/key.properties

# Editor / tooling config (user-specific, may contain local credentials)
.claude/
.obsidian/
