# .env.admin.example
#
# Template for admin provisioning scripts (provision_rep.sh, reset_password.sh).
# Copy to .env.admin and fill in. .env.admin is gitignored.
#
# RECOMMENDED: do NOT store SUPABASE_SERVICE_ROLE_KEY in a plain file.
# Source it from your password manager at runtime instead. Examples below.
#
# 1Password CLI:
#   export SUPABASE_SERVICE_ROLE_KEY="$(op read 'op://Private/Aman Supabase Dev/service_role')"
#
# Bitwarden CLI:
#   export SUPABASE_SERVICE_ROLE_KEY="$(bw get password 'Aman Supabase Dev service_role')"
#
# Then `source .env.admin` before running scripts.
# .env.admin should ONLY contain the URL + the password-manager command, never the raw key.

# Required ----------------------------------------------------------------
# IMPORTANT: every line below must use `export` and the file must use
# Unix (LF) line endings. Edit this file with `nano` from Git Bash, NOT
# with Windows Notepad — Notepad writes CRLF endings that break bash sourcing.

# Project URL
export SUPABASE_URL="https://yynhcrtdzgcgedkolgxw.supabase.co"

# Service role key.
# POC (single dev, encrypted laptop): paste the raw key inline.
#   export SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."
# Production / multi-admin: source from a password manager at runtime.
#   export SUPABASE_SERVICE_ROLE_KEY="$(op read 'op://Private/Aman Supabase Dev/service_role')"
#   export SUPABASE_SERVICE_ROLE_KEY="$(bw get password 'Aman Supabase Dev service_role')"
export SUPABASE_SERVICE_ROLE_KEY="paste_key_here"

# Optional ----------------------------------------------------------------
export DEFAULT_COUNTRY_PREFIX="+20"
